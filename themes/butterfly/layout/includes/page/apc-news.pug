//- 联萌新闻：时间轴式活动资讯列表

-
  var activities = page.posts || []
  var monthKey = ''

#apc-news
  .article-sort-title
    = page.title
    if page.apc_news_years && page.apc_news_years.length > 1
      span.apc-news-year-label= page.apc_news_year + '年'
  if page.apc_news_years && page.apc_news_years.length > 1
    - var paginationPosition = 'top'
    include apc-news-pagination.pug
  .article-sort
    each item in activities
      - var itemMonth = date(item.start, 'YYYY-MM')
      - var monthLabel = date(item.start, 'YYYY年MM月')
      if itemMonth !== monthKey
        - monthKey = itemMonth
        .article-sort-item.year.apc-news-month= monthLabel
      - var status = apc_status(item.start, item.end)
      - var hasCover = !!item.cover
      - var startText = date(item.start, 'YYYY-MM-DD')
      - var endText = item.end ? date(item.end, 'YYYY-MM-DD') : startText
      - var dateText = endText !== startText ? startText + ' ~ ' + endText : startText
      .article-sort-item.apc-news-item(class=!hasCover ? 'no-article-cover' : '')
        if hasCover
          .article-sort-item-img
            img(src=item.cover alt=item.title onerror=`this.onerror=null;this.src='${url_for(theme.error_img.post_page)}'`)
        .article-sort-item-info
          .article-sort-item-time
            i.far.fa-calendar-alt
            span.apc-news-date= dateText
            span.apc-status(class=status.class)= status.text
          h3.article-sort-item-title= item.title
          .apc-news-content!= apc_md(item.content)
  if page.apc_news_years && page.apc_news_years.length > 1
    - var paginationPosition = 'bottom'
    include apc-news-pagination.pug
