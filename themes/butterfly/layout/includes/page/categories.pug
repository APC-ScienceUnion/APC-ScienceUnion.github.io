//- 分類目錄頁：與歸檔/時間軸一致的 article-sort 卡片列表
-
  var catItems = []
  site.categories.find({ parent: { $exists: false } }).forEach(function (cat) {
    if (cat.length) catItems.push(cat)
  })
  catItems.sort(function (a, b) {
    return b.length - a.length
  })
#categories
  .article-sort-title= page.title + ' - ' + catItems.length
  .article-sort
    each cat in catItems
      - var catIcon = theme.category_per_img && theme.category_per_img[cat.name]
      - var hasCover = !!catIcon
      .article-sort-item(class=!hasCover ? 'no-article-cover' : '')
        if hasCover
          a.article-sort-item-img(href=url_for(cat.path) title=cat.name)
            img(src=catIcon alt=cat.name onerror=`this.onerror=null;this.src='${url_for(theme.error_img.post_page)}'`)
        .article-sort-item-info
          .article-sort-item-time
            i.far.fa-file-alt
            span #{cat.length} #{_p('aside.articles')}
          a.article-sort-item-title(href=url_for(cat.path) title=cat.name)= cat.name
